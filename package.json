{
  "name": "fire-nepal-homepage",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ulimit -n 8192 && WATCHPACK_POLLING=true next dev -H localhost --webpack",
    "dev:3001": "next dev -H localhost -p 3001",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test:security": "node --test scripts/security/*.test.mjs",
    "generate:investment-registry": "node scripts/generate-investment-registry.mjs",
    "verify:membership-storage": "node scripts/verify-membership-payment-storage.mjs",
    "verify:supabase-auth-env": "node scripts/verify-supabase-auth-env.mjs",
    "verify:supabase-login-routes": "node scripts/verify-supabase-login-routes.mjs",
    "db:push:remote": "env SUPABASE_CLI_DISABLE_TELEMETRY=1 DO_NOT_TRACK=1 npx --yes supabase@latest db push --db-url \"$SUPABASE_DB_URL\" --yes",
    "db:push-verify:production": "node scripts/push-verify-production-schema.mjs",
    "db:apply-verify:membership": "node scripts/apply-and-verify-supabase-membership.mjs",
    "revenue:backfill-membership": "node scripts/backfill-membership-revenue-events.mjs",
    "revenue:verify-membership": "node scripts/backfill-membership-revenue-events.mjs --verify-only"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.1",
    "axios": "^1.16.1",
    "chart.js": "latest",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "framer-motion": "^12.40.0",
    "heic2any": "^0.0.4",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.17.0",
    "next": "latest",
    "qrcode": "^1.5.4",
    "react": "latest",
    "react-chartjs-2": "latest",
    "react-dom": "latest",
    "react-pin-input": "^1.3.1",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "swr": "^2.4.1",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "latest",
    "@tailwindcss/postcss": "latest",
    "@types/node": "latest",
    "@types/qrcode": "^1.5.6",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "playwright": "^1.61.0",
    "tailwindcss": "latest",
    "typescript": "latest"
  }
}
