# Copy to `.env.local` — never commit real secrets.

# Canonical site origin for Supabase email links (password reset, sign-up confirmation).
# Required in Vercel Production so redirects in emails use https://firenepal.com (not localhost).
# Omit locally to default to the current browser origin (e.g. http://localhost:3000).
# NEXT_PUBLIC_SITE_URL=https://firenepal.com

# --- Live gold & silver (`/api/market/gold-price`) ---
# Primary: Nepal board rates are parsed from the public FENEGOSIDA homepage HTML (Fine Gold 9999 & Silver per 10 g and per tola).
# Secondary: international USD/troy oz (optional API keys below; else Yahoo GC=F / SI=F) is attached as reference only.
# GOLDAPI_API_KEY=
# METALS_DEV_API_KEY=
# METALPRICEAPI_KEY=

# --- Supabase (optional: enables cloud auth + portfolio sync) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: used by /api/cron/scheduled-reminders, membership payment proof uploads (auto-create storage bucket + upload), /admin exports, etc. (never expose to the client).

# --- Membership QR images (optional; defaults: /public/payment-qr/khalti.png, global-ime.png) ---
# NEXT_PUBLIC_MEMBERSHIP_QR_KHALTI=https://…
# NEXT_PUBLIC_MEMBERSHIP_QR_ESEWA=https://…
# NEXT_PUBLIC_MEMBERSHIP_QR_GLOBAL_IME=https://…

# --- Legacy product auth (email OTP via Resend on Vercel) ---
# Required in production when Supabase is not configured.
# When Supabase IS configured, password reset email is sent by Supabase Auth (dashboard SMTP), not Resend.
RESEND_API_KEY=
# Verified sender in Resend (must be a domain you've verified there).
# `EMAIL_FROM` is accepted as an alias for the same value.
RESEND_FROM_EMAIL="FIRE Nepal <onboarding@your-domain.com>"
# EMAIL_FROM=

# --- Automated smart-loan email reminders (Resend) ---
FIRE_NEPAL_LOGO_URL=https://firenepal.com/logo.png
CRON_SECRET=

# Optional server-side cron source until smart-loan profiles are synced to a database.
# SMART_LOAN_CRON_LOANS_JSON='[{"id":"loan-1","borrowerName":"Borrower","borrowerEmail":"borrower@example.com","borrowerPhone":"+9779800000000","lenderName":"Lender","lenderEmail":"lender@example.com","loanAmount":100000,"remainingAmount":50000,"agreementDate":"2026-05-01","dueDate":"2026-06-01","interestRate":12,"currency":"NPR","daysUntilDue":7,"daysOverdue":0}]'
SMART_LOAN_CRON_LOANS_JSON=

# Strong secret for signing session + pending-verification cookies (set in production).
# AUTH_SECRET=
